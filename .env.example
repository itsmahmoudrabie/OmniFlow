# ─────────────────────────────────────────────────────────────
# OmniFlow — Environment Variables
# Copy this file to `.env` and fill in your real values.
# On Railway, add these under Project → Variables.
# ─────────────────────────────────────────────────────────────

# ─── Server ───
PORT=8765
NODE_ENV=production
SHOPIFY_APP_URL=https://your-app.up.railway.app   # public URL of THIS server (Railway)
FRONTEND_URL=https://your-app.up.railway.app

# ─── Shopify App (from Partners → Apps → Your App → Configuration) ───
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_products,read_orders,write_orders,read_customers,read_inventory,read_fulfillments,write_fulfillments

# ─── (Legacy / single-store fallback — auto-filled by OAuth) ───
SHOPIFY_URL=
SHOPIFY_ACCESS_TOKEN=

# ─── WhatsApp Cloud API (Meta for Developers → WhatsApp → API Setup) ───
META_ACCESS_TOKEN=
PHONE_NUMBER_ID=
VERIFY_TOKEN=your-random-verify-token
CATALOG_ID=
BUSINESS_NAME=OmniFlow

# ─── AI providers (optional) ───
GEMINI_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ─── WooCommerce (optional alternative to Shopify) ───
WOO_URL=
WOO_CONSUMER_KEY=
WOO_CONSUMER_SECRET=

# ─── Misc ───
SERVER_URL=https://your-app.up.railway.app
WEBHOOK_URL=
LOYALTY_POINTS=10
COOKIE_SECRET=change-me-to-a-random-32-char-string
