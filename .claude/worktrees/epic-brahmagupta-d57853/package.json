{
  "name": "omniflow",
  "version": "1.0.0",
  "description": "OmniFlow — Shopify + WhatsApp Cloud API integration (admin dashboard + automation engine)",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "postinstall": "npm --prefix server install --omit=dev && npm --prefix dashboard-react install",
    "build": "npm --prefix dashboard-react run build",
    "start": "node server/index.js",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix dashboard-react run dev",
    "shopify:dev": "shopify app dev",
    "shopify:deploy": "shopify app deploy"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/omniflow.git"
  },
  "keywords": [
    "shopify",
    "shopify-app",
    "whatsapp",
    "whatsapp-cloud-api",
    "ecommerce",
    "automation",
    "abandoned-cart"
  ],
  "license": "UNLICENSED"
}
